{
  "name": "@xiaoba17/repoflow",
  "version": "0.1.1",
  "description": "Detect repository type and generate minimal GitHub Actions CI workflows.",
  "type": "module",
  "bin": {
    "repoflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "pack:dry-run": "npm_config_cache=/tmp/repoflow-npm-cache npm pack --dry-run",
    "release:check": "npm test && npm run build && npm run pack:dry-run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "ci",
    "init",
    "github-actions",
    "workflow",
    "automation",
    "typescript"
  ],
  "homepage": "https://github.com/xiaoba17/repoflow#readme",
  "bugs": {
    "url": "https://github.com/xiaoba17/repoflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaoba17/repoflow.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "prompts": "^2.4.2",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
